{
  "name": "manual-medicina-intensiva-pwa",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "PWA React/Vite/TypeScript para o Manual Interativo de Medicina Intensiva.",
  "scripts": {
    "dev": "vite --config vite.config.mjs --configLoader native --host 127.0.0.1",
    "build": "tsc --noEmit && vite build --config vite.config.mjs --configLoader native",
    "preview": "vite preview --config vite.config.mjs --configLoader native --host 127.0.0.1",
    "test:calculators": "node scripts/calculator-tests.mjs",
    "verify:modules": "node scripts/verify-module-hashes.mjs"
  },
  "dependencies": {
    "@clerk/backend": "^3.4.12",
    "@clerk/clerk-react": "^5.61.3",
    "@clerk/react": "^6.7.0",
    "@clerk/ui": "^1.13.0",
    "@vitejs/plugin-react": "^5.0.0",
    "framer-motion": "^11.18.2",
    "gsap": "^3.15.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "stripe": "^22.1.1",
    "typescript": "^5.6.0",
    "vite": "^7.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0"
  }
}
