# Template de variáveis de ambiente locais para marketing/remotion-story/.
#
# Como usar:
#   1. Copie este arquivo para .env (na mesma pasta):
#        cp .env.example .env        # Bash/Git Bash
#        copy .env.example .env      # cmd
#   2. Substitua os valores fake pelos seus reais.
#   3. .env já está no .gitignore raiz do repo — não vaza nos commits.
#
# Lido por: scripts/generate-narration.mjs (npm run narrate).
# Variáveis já setadas no ambiente real (export/setx/$env) têm prioridade
# sobre este .env — útil pra sobrescrever em CI.

# API key do ElevenLabs (TTS pra narração dos reels). Pega em:
# https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=sk_substitua_pela_sua_key_real_do_elevenlabs
