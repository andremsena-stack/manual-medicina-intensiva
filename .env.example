# Frontend: chave publica do Clerk.
# Use pk_test_... localmente e pk_live_... em producao.
VITE_CLERK_PUBLISHABLE_KEY=

# Frontend: manter true em producao. Use false apenas para testes locais de interface.
VITE_CLERK_BILLING_REQUIRED=true

# Frontend (opcional): Payment Link Stripe usado APENAS como fallback de desenvolvimento.
# Em producao o botao "Assinar agora" chama POST /api/create-checkout-session.
VITE_STRIPE_CHECKOUT_URL=

# Frontend (opcional): ID do Meta Pixel (Business Manager → Conjuntos de dados).
# Quando vazio, nenhuma chamada eh feita ao Facebook (zero requisicao a
# connect.facebook.net). Setar somente apos a conta BM ser liberada e o
# Pixel ser criado em events.facebook.com.
VITE_META_PIXEL_ID=

# Frontend (opcional): Cena 3D do Spline embarcada no hero da landing.
# URL .splinecode exportada de https://spline.design. Vazia = nao renderiza.
# Detalhes em src/components/HeroSpline3D.tsx.
VITE_SPLINE_SCENE_URL=

# Frontend (opcional): Modelo 3D do Sketchfab embarcado no hero da landing.
# URL de embed: https://sketchfab.com/models/<ID>/embed. Vazia = nao renderiza.
# Precedencia: Sketchfab > Spline > canvas leve. Setar so um por vez.
# Detalhes em src/components/HeroSketchfab3D.tsx.
VITE_SKETCHFAB_MODEL_URL=

# Backend Cloudflare Pages Functions: nunca prefixar com VITE_.
CLERK_SECRET_KEY=
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=price_1TZf0zAIon1Sw6HssZDB0ZPO
STRIPE_WEBHOOK_SECRET=
STRIPE_ALLOWED_STATUSES=active,trialing
APP_URL=https://manualvirtus.com.br
