# Frontend: chave publica do Clerk.
# Use pk_test_... localmente e pk_live_... em producao.
VITE_CLERK_PUBLISHABLE_KEY=

# Frontend: manter true em producao. Use false apenas para testes locais de interface.
VITE_CLERK_BILLING_REQUIRED=true

# Frontend (opcional): Payment Link Stripe usado APENAS como fallback de desenvolvimento.
# Em producao o botao "Assinar agora" chama POST /api/create-checkout-session.
VITE_STRIPE_CHECKOUT_URL=

# Frontend (opcional): Payment Link da fase fundadora (R$ 29,99 one-time).
# Se nao definido, usa o link prod live hardcoded em AuthGate.tsx.
# Em DEV/TEST, apontar para um Payment Link de teste:
# https://buy.stripe.com/test_xxxxxxxx
VITE_FOUNDER_PAYMENT_LINK=

# Backend Cloudflare Pages Functions: nunca prefixar com VITE_.
CLERK_SECRET_KEY=
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=price_1TZf0zAIon1Sw6HssZDB0ZPO
STRIPE_WEBHOOK_SECRET=
STRIPE_ALLOWED_STATUSES=active,trialing
APP_URL=https://manualvirtus.com.br
